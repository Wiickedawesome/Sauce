# Never bake secrets into the image — .env is mounted at runtime via docker-compose.yml
.env
.env.local
.env.*.local

# Version control
.git
.github

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# Local data — mounted as a volume at runtime
data/

# Editor / OS noise
.DS_Store
*.swp
*.swo
