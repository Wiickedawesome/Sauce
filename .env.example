# ─────────────────────────────────────────────────────────────────────────────
# Sauce — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to the repository.
# ─────────────────────────────────────────────────────────────────────────────

# ── Broker (Alpaca) ───────────────────────────────────────────────────────────
# Get these from: https://alpaca.markets → Your account → API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# true = paper trading (safe), false = live trading (real money). Default: true.
ALPACA_PAPER=true

# ── LLM ──────────────────────────────────────────────────────────────────────
# Anthropic API key for Claude.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic model name.
LLM_MODEL=claude-sonnet-4-6

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Leave SUPABASE_* unset to use local SQLite (data/sauce.db).
# Set all three to use Supabase PostgreSQL.
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Get from: Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# ── Trading Universe ──────────────────────────────────────────────────────────
# Comma-separated list of equity tickers to trade.
TRADING_UNIVERSE_EQUITIES=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,AVGO,CRM,ORCL,ADBE,AMD,INTC,QCOM,CSCO,JPM,BAC,GS,MS,V,MA,AXP,BLK,SCHW,C,UNH,JNJ,LLY,PFE,ABBV,MRK,TMO,ABT,BMY,AMGN,WMT,COST,HD,MCD,NKE,SBUX,TGT,LOW,PG,KO,PEP,XOM,CVX,COP,NEE,CAT,DE,HON,UNP,BA,GE,SPY,QQQ,IWM,DIA,XLF,XLE,XLK,XLV,ARKK,GLD,SLV,TLT

# Comma-separated list of crypto pairs to trade (Alpaca format).
# Only liquid /USD pairs — avoid /USDC, /USDT, /BTC (stablecoin/cross pairs).
TRADING_UNIVERSE_CRYPTO=BTC/USD,ETH/USD,SOL/USD,LINK/USD,AVAX/USD,DOGE/USD,XRP/USD,ADA/USD,DOT/USD,MATIC/USD,UNI/USD,AAVE/USD,SHIB/USD,LTC/USD,BCH/USD,ALGO/USD,ATOM/USD,FIL/USD,NEAR/USD,APT/USD,ARB/USD,OP/USD,MKR/USD,GRT/USD,RENDER/USD,INJ/USD,SUI/USD,SEI/USD,PEPE/USD,FET/USD

# ── Risk Limits ───────────────────────────────────────────────────────────────
# Maximum total portfolio exposure as a fraction of NAV (1.0 = 100%, no leverage).
MAX_PORTFOLIO_EXPOSURE=1.0

# If portfolio daily loss exceeds this fraction of NAV, trading is paused automatically.
MAX_DAILY_LOSS_PCT=0.02

# Signals with confidence below this value are treated as "hold" and skipped.
MIN_CONFIDENCE=0.30

# Market data older than this many seconds is considered stale and will block a trade.
DATA_TTL_SECONDS=120
EQUITY_DATA_TTL_SECONDS=30
CRYPTO_DATA_TTL_SECONDS=120
OPTION_DATA_TTL_SECONDS=60

# If the live quote deviates more than this fraction from the signal's price reference,
# the Execution agent will veto the order.
MAX_PRICE_DEVIATION=0.01

# Cancel open orders that have gone stale before they consume buying power for too long.
STALE_ORDER_CANCEL_EQUITY_MINUTES=15
STALE_ORDER_CANCEL_CRYPTO_MINUTES=30

# Pause new entries after repeated losses to force a cool-off window.
MAX_CONSECUTIVE_LOSSES=5
CONSECUTIVE_LOSS_COOLDOWN_HOURS=24
INTRADAY_REGIME_REFRESH_HOURS=4

# By default, intraday equity/options entries are blocked on delayed IEX data.
# Set to true only if you explicitly want paper-mode delayed-entry experimentation.
ALLOW_DELAYED_EQUITY_ENTRIES=false

# Net-P&L attribution assumptions used in trade logging and performance reports.
EQUITY_FEE_BPS=0
CRYPTO_FEE_BPS=15
OPTION_FEE_BPS=50
EQUITY_SLIPPAGE_BPS=5
CRYPTO_SLIPPAGE_BPS=15
OPTION_SLIPPAGE_BPS=50
PERFORMANCE_RISK_FREE_RATE=0.05

# Research outputs from walk-forward calibration and point-in-time universes.
STRATEGY_PROFILE_PATH=data/research/strategy_profiles.json
RESEARCH_EQUITY_UNIVERSE_PATH=data/research/equity_universe_history.json

# ── Market Data Feed ──────────────────────────────────────────────────────────
# 'iex' = free tier data feed (default, required for free Alpaca accounts)
# 'sip' = paid SIP data feed (requires Alpaca paid subscription)
DATA_FEED=iex

# ── Options ───────────────────────────────────────────────────────────────────
# Enable the integrated options entry/exit pipeline explicitly.
OPTIONS_ENABLED=false

# ── Dynamic Screener ─────────────────────────────────────────────────────────
# When enabled, scans the full Alpaca equity market each loop to discover
# candidates dynamically. The .env TRADING_UNIVERSE_EQUITIES list becomes an
# "always include" watchlist. Crypto is unaffected — always uses its .env list.
SCREENER_ENABLED=false
SCREENER_MAX_CANDIDATES=30
SCREENER_MIN_DOLLAR_VOLUME=5000000
SCREENER_PRICE_MIN=5.0
SCREENER_PRICE_MAX=5000.0

# ── Safety ────────────────────────────────────────────────────────────────────
# Set to true to halt all trading immediately. Manual reset required.
TRADING_PAUSE=false

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root).
DB_PATH=data/sauce.db

# ── Prompt Versioning ─────────────────────────────────────────────────────────
# Increment this when any agent prompt changes to maintain audit traceability.
PROMPT_VERSION=v1
